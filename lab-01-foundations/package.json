{
  "name": "claude-code-lab-01-foundations",
  "version": "1.0.0",
  "description": "Claude Code Mastery — Lab 1: Foundations. A simple Express API + React frontend for your first Claude Code session.",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "nodemon src/api/server.js",
    "dev:client": "cd src/client && npx vite --port 3001",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src/"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
